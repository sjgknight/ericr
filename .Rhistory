resp <- tolower(readline(""))
if(resp == "y"){
content_new = rlang::exec(get_pages, !!!args_to_pass)
content_new = list(first = as.data.frame(content_first), second = as.data.frame(content_new))
content_new = dplyr::bind_rows(content_new$first, content_new$second)
}}
if(check == FALSE){
